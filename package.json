    "@langchain/openai": "^0.3.0",
    "@sentry/node": "^8.40.0",
    "@slack/webhook": "^7.0.6",
    "axios": "^1.7.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.0.0",
    "cheerio": "^1.0.0",
    "chromadb": "^1.8.1",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "discord.js": "^14.16.3",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "joi": "^17.13.3",
    "json2csv": "^5.0.7",
    "jsonwebtoken": "^9.0.2",
    "lodash": "^4.17.21",
    "mongoose": "^8.8.0",
    "multer": "^1.4.5-lts.1",
