{
  "name": "autonomous-ai-web-extraction-agent",
  "version": "1.0.0",
  "description": "Production-grade Autonomous AI Web Data Extraction Agent using LangGraph architecture",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc && tsc-alias",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "docker:build": "docker build -t autonomous-ai-agent .",
    "docker:run": "docker run -p 3000:3000 --env-file .env autonomous-ai-agent",
    "dashboard:dev": "cd dashboard && npm run dev",
    "dashboard:build": "cd dashboard && npm run build",
    "setup": "node scripts/setup.js",
    "scraping-worker": "node dist/workers/scraping-worker.js",
    "analytics-worker": "node dist/workers/analytics-worker.js"
  },
  "keywords": [
    "ai-agent",
    "web-scraping",
    "langgraph",
    "autonomous",
    "data-extraction",
    "llm",
    "playwright"
  ],
  "author": "Autonomous AI Systems",
  "license": "MIT",
  "dependencies": {
    "@google-cloud/vision": "^4.3.0",
    "@langchain/community": "^0.3.0",
    "@langchain/core": "^0.3.0",
