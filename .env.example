# ============================================
# Autonomous AI Web Data Extraction Agent
# Environment Configuration
# ============================================
# Copy this file to .env and fill in your credentials
# Uncomment sections for providers you want to use

# ============================================
# Server Configuration
# ============================================
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
API_VERSION=v1

# ============================================
# LLM Provider Selection
# ============================================
# Choose ONE of the following: openai | anthropic | groq | qwen | deepseek | openclaw
LLM_PROVIDER=openai

# ============================================
# OpenAI Configuration
# ============================================
# Primary provider - most feature-complete
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.3
OPENAI_MAX_TOKENS=4000

# ============================================
# Anthropic Configuration
# ============================================
# To use: set LLM_PROVIDER=anthropic
# Features: Text, JSON, Tools, Image Analysis
# Limitations: No embeddings API
# ANTHROPIC_API_KEY=your-anthropic-api-key
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
# ANTHROPIC_TEMPERATURE=0.3
# ANTHROPIC_MAX_TOKENS=4000

# ============================================
# Groq Configuration
# ============================================
# To use: set LLM_PROVIDER=groq
# Features: Text, JSON, Tools (fast inference)
# Limitations: No image analysis, No embeddings
# GROQ_API_KEY=gsk-your-groq-api-key
# GROQ_MODEL=mixtral-8x7b-32768
# GROQ_TEMPERATURE=0.3
# GROQ_MAX_TOKENS=4000

# ============================================
# Qwen Configuration (Alibaba Cloud)
# ============================================
# To use: set LLM_PROVIDER=qwen
# Features: Text, JSON, Tools, Image Analysis
# Limitations: No embeddings API
# QWEN_API_KEY=your-qwen-api-key
# QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# QWEN_MODEL=qwen-turbo
# QWEN_TEMPERATURE=0.3
# QWEN_MAX_TOKENS=4000

# ============================================
# Deepseek Configuration
# ============================================
# To use: set LLM_PROVIDER=deepseek
# Features: Text, JSON, Tools, Image Analysis
# Limitations: No embeddings API
# DEEPSEEK_API_KEY=sk-your-deepseek-api-key
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_TEMPERATURE=0.3
# DEEPSEEK_MAX_TOKENS=4000

# ============================================
# OpenClaw Configuration
# ============================================
# To use: set LLM_PROVIDER=openclaw
# Features: Text, JSON, Tools, Image Analysis
# Limitations: No embeddings API
# OPENCLAW_API_KEY=your-openclaw-api-key
# OPENCLAW_BASE_URL=https://api.openclaw.com/v1
# OPENCLAW_MODEL=openclaw-7b
# OPENCLAW_TEMPERATURE=0.3
# OPENCLAW_MAX_TOKENS=4000

# ============================================
# LangGraph Configuration
# ============================================
LANGGRAPH_API_KEY=your-langgraph-api-key
LANGGRAPH_PROJECT=autonomous-ai-agent
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your-langsmith-api-key

# ============================================
# Database - MongoDB
# ============================================
MONGODB_URI=mongodb://localhost:27017/autonomous_ai_agent
MONGODB_DB_NAME=autonomous_ai_agent

# ============================================
# Database - Redis
# ============================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================
# Vector Database Configuration
# ============================================
# Options: chroma | pinecone
VECTOR_DB_PROVIDER=chroma

# Chroma (Local/Cloud)
CHROMA_URL=http://localhost:8000
CHROMA_COLLECTION=agent_memory

# Pinecone (Alternative)
# PINECONE_API_KEY=your-pinecone-api-key
# PINECONE_ENVIRONMENT=us-east-1
# PINECONE_INDEX=agent-memory

# ============================================
# Search APIs
# ============================================
SERPAPI_KEY=your-serpapi-key
BING_API_KEY=your-bing-api-key
GOOGLE_API_KEY=your-google-api-key
GOOGLE_CX=your-google-custom-search-cx
DUCKDUCKGO_ENABLED=true

# ============================================
# Scraping Configuration
# ============================================
SCRAPER_HEADLESS=true
SCRAPER_TIMEOUT=30000
SCRAPER_CONCURRENCY=5
SCRAPER_RETRY_ATTEMPTS=3
SCRAPER_DELAY_MS=2000
PROXY_ROTATION_ENABLED=false
PROXY_LIST=
USER_AGENT_ROTATION_ENABLED=true

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# Authentication
# ============================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# ============================================
# File Storage
# ============================================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# ============================================
# Notifications
# ============================================
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=
EMAIL_FROM=noreply@autonomous-ai-agent.com

# ============================================
# Monitoring & Observability
# ============================================
SENTRY_DSN=
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com

# ============================================
# OCR & Vision
# ============================================
TESSERACT_LANG=eng
GOOGLE_VISION_API_KEY=

# ============================================
# Scheduling
# ============================================
SCRAPING_SCHEDULE=0 2 * * *
ANALYTICS_SCHEDULE=0 6 * * *

# ============================================
# Feature Flags
# ============================================
ENABLE_SELF_HEALING=true
ENABLE_MULTI_MODAL=true
ENABLE_MEMORY_LEARNING=true
ENABLE_REAL_TIME_ANALYTICS=true
ENABLE_SLACK_NOTIFICATIONS=false
ENABLE_EMAIL_NOTIFICATIONS=false

# File Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# External Services
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=
EMAIL_FROM=noreply@autonomous-ai-agent.com

# Monitoring & Analytics
SENTRY_DSN=
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com

# OCR & Vision
TESSERACT_LANG=eng
GOOGLE_VISION_API_KEY=

# Scheduling
SCRAPING_SCHEDULE=0 2 * * *
ANALYTICS_SCHEDULE=0 6 * * *

# Feature Flags
ENABLE_SELF_HEALING=true
ENABLE_MULTI_MODAL=true
ENABLE_MEMORY_LEARNING=true
ENABLE_REAL_TIME_ANALYTICS=true
ENABLE_SLACK_NOTIFICATIONS=false
ENABLE_EMAIL_NOTIFICATIONS=false
